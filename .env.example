# MagicFinance — Environment Variables
# ======================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ─── Reddit API ───────────────────────────────────────────────────────────────
# Get these from: https://www.reddit.com/prefs/apps
# Create a "script" type app
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=MagicFinance/1.0 by u/your_reddit_username

# ─── NewsAPI ──────────────────────────────────────────────────────────────────
# Free tier: https://newsapi.org/register (100 req/day, 1 month history)
NEWSAPI_KEY=your_newsapi_key

# ─── Slack ────────────────────────────────────────────────────────────────────
# Incoming Webhook URL from your Slack app
# Reuse the same webhook as Nanobot (#all-nanobot channel)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
